#!/bin/bash
# Auto-tag beta versions on dev branch commits

BRANCH=$(git branch --show-current)
if [ "$BRANCH" != "dev" ]; then
    exit 0
fi

# Don't tag if this commit is already a release tag
COMMIT_MSG=$(git log -1 --pretty=%s)
if echo "$COMMIT_MSG" | grep -q "^Release v"; then
    exit 0
fi

# Read base version
VERSION_FILE="VERSION"
if [ -f "$VERSION_FILE" ]; then
    BASE_VERSION=$(cat "$VERSION_FILE" | tr -d '[:space:]')
else
    BASE_VERSION="1.0.0"
fi

# Find the highest existing beta number for this version
LAST_BETA=$(git tag -l "v${BASE_VERSION}-beta.*" | sed "s/v${BASE_VERSION}-beta\.//" | sort -n | tail -1)
if [ -z "$LAST_BETA" ]; then
    NEXT_BETA=1
else
    NEXT_BETA=$((LAST_BETA + 1))
fi

BETA_TAG="v${BASE_VERSION}-beta.${NEXT_BETA}"
git tag "$BETA_TAG" >/dev/null 2>&1
echo "Tagged: $BETA_TAG"
